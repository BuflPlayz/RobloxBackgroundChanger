{
  "manifest_version": 3,
  "name": "Roblox Background Changer",
  "version": "1.0",
  "description": "Replace the Roblox.com background with your own image.",
  "permissions": ["storage", "activeTab", "unlimitedStorage"],
  "host_permissions": ["*://*.roblox.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Roblox Background Changer"
  },
  "content_scripts": [
    {
      "matches": ["*://*.roblox.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
